{
  "name": "tap",
  "description": "TDD-driven development plugin with subagent spawns. Drives red → green → refactor cycle by delegating each phase to a focused subagent.",
  "version": "0.6.0",
  "author": {
    "name": "Ben"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/context-pressure.sh"
          }
        ]
      }
    ]
  },
  "repository": "https://github.com/bjspdn/tap-skills",
  "homepage": "https://github.com/bjspdn/tap-skills",
  "license": "MIT",
  "keywords": [
    "tdd",
    "test-driven-development",
    "subagents",
    "red-green-refactor",
    "claude-code"
  ]
}
